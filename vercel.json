{
  "buildCommand": "cd front-web && npm install && npm run build",
  "outputDirectory": "front-web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://65.1.105.90/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://65.1.105.90/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}
